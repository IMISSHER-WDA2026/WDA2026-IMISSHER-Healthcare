# Server
PORT=3000

# Database (Supabase Postgres or any PostgreSQL)
# For Supabase, copy Transaction pooler URI and append ?sslmode=require
# DATABASE_URL=postgresql://postgres.xxx:[PASSWORD]@aws-0-ap-southeast-1.pooler.supabase.com:6543/postgres?sslmode=require
DATABASE_URL=postgres://postgres:password123@localhost:5432/imissher_local_db
TYPEORM_SYNCHRONIZE=true
# DB_SSL=true when using Supabase/managed Postgres requiring TLS
DB_SSL=false

# CORS (comma-separated origins, leave empty to allow all)
# CORS_ORIGIN=http://localhost:8081,http://localhost:5173,https://your-sos-web.vercel.app

# JWT
JWT_SECRET=imissher-dev-secret
JWT_EXPIRES_IN=7d

# Optional cloud chatbot integration
# CHAT_MODEL_API_URL=
# CHAT_MODEL_API_KEY=

# Face recognition AI service
FACE_RECOGNITION_API_URL=http://localhost:8001/api/v1/face/recognize
FACE_RECOGNITION_MATCH_THRESHOLD=0.82

# Runtime storage
# IMISSHER_DATA_DIR=.runtime-data
# IMISSHER_UPLOAD_DIR=.runtime-data/uploads

# Optional custom medicine catalog directory
# IMISSHER_MEDICINE_DATA_DIR=../ai/data

# Seeded test account (created automatically if not found)
IMISSHER_TEST_ACCOUNT_EMAIL=test@imissher.dev
IMISSHER_TEST_ACCOUNT_PASSWORD=Test@123456
IMISSHER_TEST_ACCOUNT_FULL_NAME=Tai Khoan Test IMISSHER
