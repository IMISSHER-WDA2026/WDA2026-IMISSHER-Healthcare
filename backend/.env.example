# Server
PORT=3000

# Database (Supabase Postgres or any PostgreSQL)
# For Supabase, copy Transaction pooler URI and append ?sslmode=require
# DATABASE_URL=postgresql://postgres.xxx:[PASSWORD]@aws-0-ap-southeast-1.pooler.supabase.com:6543/postgres?sslmode=require
DATABASE_URL=postgres://postgres:password123@localhost:5432/healthcare_local_db
TYPEORM_SYNCHRONIZE=true
# DB_SSL=true when using Supabase/managed Postgres requiring TLS
DB_SSL=false

# CORS (comma-separated origins, leave empty to allow all)
# CORS_ORIGIN=http://localhost:8081,http://localhost:5173,https://your-sos-web.vercel.app

# JWT
# Use a strong random value (at least 32 characters).
JWT_SECRET=replace-with-a-strong-random-secret-min-32-chars
JWT_EXPIRES_IN=7d

# API docs exposure (default: enabled in non-production, disabled in production)
# ENABLE_SWAGGER=false

# Optional cloud chatbot integration
RAG_MODEL_API_URL=https://<your-hf-username>-healthcare-rag-service.hf.space/api/v1/rag/answer
RAG_MODEL_API_TOKEN=<your-huggingface-token>
RAG_MODEL_TIMEOUT_MS=120000
# Backward compatibility aliases (optional)
# CHAT_MODEL_API_URL=
# CHAT_MODEL_API_KEY=

# Face recognition AI service
FACE_RECOGNITION_API_URL=https://<your-hf-username>-healthcare-face-service.hf.space/api/v1/face/recognize
FACE_RECOGNITION_API_TOKEN=<your-huggingface-token>
FACE_RECOGNITION_REQUEST_MODE=multipart
FACE_RECOGNITION_TIMEOUT_MS=120000
FACE_RECOGNITION_MATCH_THRESHOLD=0.82

# Supabase Storage (file uploads)
SUPABASE_URL=https://<project>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_UPLOADS_BUCKET=uploads

# Optional custom medicine catalog directory
# HEALTHCARE_MEDICINE_DATA_DIR=../ai/data

# Seeded test account (created automatically if not found)
HEALTHCARE_TEST_ACCOUNT_EMAIL=test@healthcare.dev
HEALTHCARE_TEST_ACCOUNT_PASSWORD=Test@123456
HEALTHCARE_TEST_ACCOUNT_FULL_NAME=Tai Khoan Test Healthcare